# Where the hosted Gwanggo API lives. The studio sends all generation
# requests here (it appends /api/v1/...). Default points at the official API.
NEXT_PUBLIC_API_URL=https://gwanggo.jocoding.io

# Where users go to create/manage API keys (the hosted dashboard).
NEXT_PUBLIC_DASHBOARD_URL=https://gwanggo.jocoding.io/dashboard/api-keys
